# ─── BabyApp Backend — Variables de entorno ───────────────────────────────────
# Copia este archivo a .env y completa los valores reales.
# NUNCA commitear .env con valores reales.

# MongoDB
MONGO_URI=mongodb://localhost:27017
DB_NAME=babyapp

# Firebase Auth
FIREBASE_PROJECT_ID=proyectos-hobbys-495300

# Servidor
PORT=3001
BASE_URL=http://localhost:3001

# Frontend (CORS) — en producción poner la URL real del frontend
FRONTEND_URL=http://localhost:4200

# Uploads locales
UPLOAD_DIR=./uploads

# AWS S3 privado para fotos
AWS_REGION=sa-east-1
S3_PHOTOS_BUCKET=babyapp-photos-264105488314-sa-east-1
S3_PRESIGN_TTL_SECONDS=900
THEMEALDB_API_KEY=1

# ─── BabyApp Backend — Variables de entorno ───────────────────────────────────
# Copia este archivo a .env y completa los valores reales.
# NUNCA commitear .env con valores reales.

# MongoDB
MONGO_URI=mongodb://localhost:27017
DB_NAME=babyapp

# JWT — OBLIGATORIO: genera un secreto seguro con: openssl rand -hex 32
JWT_SECRET=

# Servidor
PORT=3001
BASE_URL=http://localhost:3001

# Frontend (CORS) — en producción poner la URL real del frontend
FRONTEND_URL=http://localhost:4200

# Uploads locales
UPLOAD_DIR=./uploads

# Google OAuth — ID del cliente de Google Cloud Console
GOOGLE_CLIENT_ID=1057417146171-d5ih4k9gggjuvqtaoqpoj8govc6nvk6r.apps.googleusercontent.com
